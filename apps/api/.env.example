# apps/api/.env.example
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to Git.

# ■■ Database ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Local dev: use the Docker Compose credentials from Task 9
DATABASE_URL=postgresql://homerenter:secret_dev@localhost:5432/homerenter_dev

# ■■ Redis ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
REDIS_URL=redis://localhost:6379

# ■■ Authentication ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
# Generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_32_BYTE_HEX_STRING
JWT_SECRET=REPLACE_WITH_32_BYTE_HEX_STRING

# ■■ MinIO (Object Storage) ■■■■■■■■■■■■■■■■■■■■■■■■■■■■
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=home-renter-media

# ■■ Server ■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■
PORT=3001
ALLOWED_ORIGIN=http://localhost:3000
NODE_ENV=development
