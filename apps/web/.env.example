# apps/web/.env.example
# Next.js exposes NEXT_PUBLIC_ variables to the browser.
# Variables WITHOUT that prefix stay server-side only.

# ■■ API base URL (server-side) ■■■■■■■■■■■■■■■■■■■■■■■■
API_BASE_URL=http://localhost:3001

# ■■ Public variables (sent to the browser) ■■■■■■■■■■■■
# Used by Leaflet map component in Sprint 3
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Base URL of the API, accessible from the browser for SSE connections
NEXT_PUBLIC_API_URL=http://localhost:3001
